{
  "name": "caden-exp-bill-coworker",
  "version": "0.1.0",
  "private": true,
  "main": "electron-dist/main.js",
  "scripts": {
    "copy-vendors": "node scripts/copy-vendors.js",
    "postinstall": "node scripts/copy-vendors.js",
    "dev": "next dev -p 3000",
    "dev:preview": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run",
    "eval": "tsx evals/runDemos.eval.ts",
    "preflight": "node scripts/preflight.js",
    "electron:build-next": "next build",
    "electron:copy-standalone": "node scripts/copy-standalone.js",
    "electron:build-main": "tsc -p tsconfig.electron.json",
    "electron:build": "npm run electron:build-next && npm run electron:copy-standalone && npm run electron:build-main",
    "preelectron:dev": "npm run preflight",
    "electron:dev": "npm run electron:build && electron .",
    "preelectron:dev:fast": "npm run electron:build-main",
    "electron:dev:fast": "concurrently -k -s first -n next,electron -c blue,magenta \"next dev -p 3100\" \"wait-on http://127.0.0.1:3100 && cross-env ELECTRON_DEV_URL=http://127.0.0.1:3100 electron .\"",
    "electron:dist": "npm run electron:build && electron-builder --mac",
    "electron:dist:zip": "npm run electron:build && electron-builder --mac --config.mac.target=zip"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@google/genai": "^1.50.1",
    "@univerjs/core": "^0.21.1",
    "@univerjs/design": "^0.21.1",
    "@univerjs/docs": "^0.21.1",
    "@univerjs/docs-ui": "^0.21.1",
    "@univerjs/engine-formula": "^0.21.1",
    "@univerjs/engine-render": "^0.21.1",
    "@univerjs/facade": "^0.5.5",
    "@univerjs/icons": "^1.1.1",
    "@univerjs/sheets": "^0.21.1",
    "@univerjs/sheets-formula": "^0.21.1",
    "@univerjs/sheets-formula-ui": "^0.21.1",
    "@univerjs/sheets-ui": "^0.21.1",
    "@univerjs/slides": "^0.21.1",
    "@univerjs/slides-ui": "^0.21.1",
    "@univerjs/ui": "^0.21.1",
    "braintrust": "^3.9.0",
    "electron-store": "^8.2.0",
    "next": "^14.2.34",
    "openai": "^6.37.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/get-port": "^4.0.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "chart.js": "^4.5.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "d3": "^7.9.0",
    "echarts": "^5.6.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "jsdom": "^29.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.salesforce.coworker",
    "productName": "Salesforce Coworker",
    "directories": {
      "output": "dist-electron",
      "buildResources": "electron/assets"
    },
    "files": [
      "electron-dist/**/*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "electron-next",
        "to": "app/electron-next"
      }
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.business",
      "icon": "electron/assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "identity": null
    }
  }
}
